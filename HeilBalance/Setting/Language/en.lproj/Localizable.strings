"八段锦第一式：动作说明" =  "Stand upright with your feet shoulder-width apart.Slowly raise your hands in front of the body, palms facing upward, and gently stretch the arms verhead. Return slowly to the starting position.";

"八段锦第一式：身体感知" = "Notice the gentle stretch through the body, a natural lengthening of the spine, and calm breathing。";

"八段锦第一式：动作说明" = "Stand upright with your feet shoulder-width apart. Slowly raise your hands in front of the body, palms facing upward, and gently stretch the arms overhead. Return slowly to the starting position.";
"八段锦第一式：身体感知" = "Notice the gentle stretch through the body, a natural lengthening of the spine, and calm breathing.";

"八段锦第二式：动作说明" = "Adopt a stable stance with slightly bent knees. Open the arms to each side as if drawing a bow, alternating left and right.";
"八段锦第二式：身体感知" = "Feel the opening of the upper body and the balance between both sides.";

"八段锦第三式：动作说明" = "Lift one hand gently upward while the other moves downward. Keep the torso upright and alternate sides.";
"八段锦第三式：身体感知" = "Notice the vertical stretch and a sense of stability through the body.";

"八段锦第四式：动作说明" = "Stand upright with arms relaxed. Slowly turn the head to one side, allowing the gaze to follow.";
"八段锦第四式：身体感知" = "Feel the gentle movement in the neck and upper back.";

"八段锦第五式：动作说明" = "Stand with feet apart and gently incline the torso forward. Move the head and upper body softly from side to side.";
"八段锦第五式：身体感知" = "Notice coordination and smooth, flowing movement.";

"八段锦第六式：动作说明" = "From a standing position, slowly bend forward and reach the hands toward the feet. Return to standing in a controlled manner.";
"八段锦第六式：身体感知" = "\tFeel the stretch along the back and legs, adjusting to your comfort level.";

"八段锦第七式：动作说明" = "Stand firmly and alternately extend the fists forward. Maintain controlled and smooth movements.";
"八段锦第七式：身体感知" = "Notice strength, stability, and a sense of focus.";

"八段锦第八式：动作说明" = "Slowly lift the heels off the ground and gently lower them back down. Maintain an upright posture.";
"八段锦第八式：身体感知" = "Feel balance, rhythm, and light upward movement.";
